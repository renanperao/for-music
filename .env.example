# ─────────────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: somente em rotas server-side. NUNCA expor ao browser.
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────────────
# Asaas (pagamentos PIX/cartão + split com repasse bloqueado)
# Sandbox: https://api-sandbox.asaas.com/v3
# Produção: https://api.asaas.com/v3
# ─────────────────────────────────────────────────────────────────────
ASAAS_API_URL=https://api-sandbox.asaas.com/v3
ASAAS_API_KEY=
# Token compartilhado para validar webhooks recebidos da Asaas
ASAAS_WEBHOOK_TOKEN=
# Wallet ID da plataforma (recebe os 10% de comissão)
ASAAS_PLATFORM_WALLET_ID=

# ─────────────────────────────────────────────────────────────────────
# Cloudflare R2 (armazenamento dos áudios entregues)
# ─────────────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=for-music-deliveries
# URL pública (CDN ou bucket público) usada para servir áudios assinados
R2_PUBLIC_BASE_URL=

# ─────────────────────────────────────────────────────────────────────
# Plataforma
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Comissão da plataforma em pontos percentuais inteiros
PLATFORM_FEE_PERCENT=10
# Janela de auto-aprovação (em dias) — usado pelo app ao calcular auto_approve_at
AUTO_APPROVE_AFTER_DAYS=5
# Máximo de revisões permitidas por pedido
MAX_REVISIONS=2

# ─────────────────────────────────────────────────────────────────────
# Cron / segurança server-side
# ─────────────────────────────────────────────────────────────────────
# Token usado pela Edge Function de liberação de repasse (chamada após
# auto-aprovação no pg_cron) para autenticar contra o endpoint da app.
INTERNAL_JOB_TOKEN=
